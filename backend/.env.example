# --- Core ---
ENVIRONMENT=dev

# --- Security ---
JWT_SECRET=change-me-in-prod
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXP_MINUTES=1440
COOKIE_NAME=access_token
COOKIE_SECURE=false
COOKIE_SAMESITE=lax

# --- Datastores ---
# Optional: override the DB URL (useful for local dev without Postgres)
# DATABASE_URL=sqlite:///./data/vidyasetu.db

# Supabase Postgres (recommended):
# Set these to the values from Supabase (Project Settings → Database → Connection string)
# POSTGRES_HOST=db.<project-ref>.supabase.co
# POSTGRES_PORT=5432
# POSTGRES_DB=postgres
# POSTGRES_USER=postgres
# POSTGRES_PASSWORD=your-supabase-db-password
# POSTGRES_SSLMODE=require

POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=vidyasetu
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_SSLMODE=prefer

REDIS_URL=redis://localhost:6379/0

# Optional: seed an admin user on startup
# ADMIN_EMAIL=admin@example.com
# ADMIN_PASSWORD=change-me

# --- OpenAI ---
OPENAI_API_KEY=change-me
OPENAI_MODEL_LARGE=gpt-4o
OPENAI_MODEL_SMALL=gpt-4o-mini

# --- Embeddings ---
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# --- CORS ---
ALLOWED_ORIGINS=["http://localhost:8080"]

# --- Cost tracking (tune as needed) ---
USD_TO_INR=83.0
GPT4O_IN_USD_PER_1M=5.0
GPT4O_OUT_USD_PER_1M=15.0
GPT4OMINI_IN_USD_PER_1M=0.15
GPT4OMINI_OUT_USD_PER_1M=0.60
